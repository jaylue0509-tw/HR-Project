# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Frontend (VITE_ prefix, exposed to browser) ──────────────────────────────

# HR Super Admin credentials (AuthContext.tsx)
VITE_ADMIN_EMAIL="admin@hr.com"
VITE_ADMIN_PASSWORD="admin1234"

# Gemini API Keys (apiKeyManager.ts) — use _1~_5 for rotation, or single fallback
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
VITE_GEMINI_API_KEY_1="YOUR_GEMINI_API_KEY_1"
VITE_GEMINI_API_KEY_2="YOUR_GEMINI_API_KEY_2"

# Backend API URL (HRAccountManager.tsx)
VITE_API_URL="https://hr-project-96mr.onrender.com"

# ─── Backend (server/index.js, server/db.js) ──────────────────────────────────

# Default admin seed credentials for SQLite (db.js)
ADMIN_EMAIL="admin@hr.com"
ADMIN_PASSWORD="admin1234"

# CORS allowed origin for production (server/index.js)
ALLOW_ORIGIN="https://your-frontend-domain.com"

# ─── PowerShell key rotation (AutoSwitchGemini.ps1) ───────────────────────────
# Set these as Windows User environment variables before running the script
GEMINI_KEY_1="YOUR_GEMINI_API_KEY_1"
GEMINI_KEY_2="YOUR_GEMINI_API_KEY_2"

# ─── Firebase (firebase.ts) ────────────────────────────────────────────────────
# Optional: override hardcoded values for multi-environment deployment
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
